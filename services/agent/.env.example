ANTHROPIC_API_KEY=sk-ant-xxx
GEMINI_API_KEY=
PORT=8000
AI_CONFIDENCE_THRESHOLD=0.70
# Swappable model: "anthropic" (Claude), "gemini" (Google), or "heuristic" (offline, no key).
LLM_PROVIDER=anthropic
# Model id for the chosen provider, e.g. claude-sonnet-5 or gemini-2.5-flash.
LLM_MODEL=claude-sonnet-5
