# Resolution AI — Web Frontend
# The frontend only talks to the core API over HTTP. No direct DB access.
#
# Point at the core service in production/integration:
NEXT_PUBLIC_API_URL=http://localhost:3000
#
# ...or run fully self-contained against the built-in mock API (no backend
# required) by pointing at the bundled route handlers instead:
# NEXT_PUBLIC_API_URL=/api/mock
